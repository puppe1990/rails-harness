#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

maybe_bundle_exec() {
  if [ -f "Gemfile" ]; then
    bundle exec "$@"
  else
    "$@"
  fi
}

has_gem() {
  local gem_name="$1"
  grep -q "$gem_name" Gemfile.lock 2>/dev/null || grep -q "$gem_name" Gemfile 2>/dev/null
}

echo "==> check_harness"
script/check_harness

if [ -f ".rubocop.yml" ] || has_gem "rubocop"; then
  echo "==> rubocop"
  maybe_bundle_exec rubocop
else
  echo "==> rubocop skipped"
fi

if has_gem "brakeman"; then
  echo "==> brakeman"
  maybe_bundle_exec brakeman -q
else
  echo "==> brakeman skipped"
fi

if has_gem "bundler-audit"; then
  echo "==> bundle-audit"
  maybe_bundle_exec bundle-audit check --update
else
  echo "==> bundle-audit skipped"
fi

echo "==> check_architecture"
script/check_architecture

if [ -d "spec/architecture" ] && has_gem "rspec-rails"; then
  echo "==> rspec architecture"
  maybe_bundle_exec rspec spec/architecture
else
  echo "==> rspec architecture skipped"
fi
