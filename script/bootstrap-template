#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
Usage:
  script/bootstrap-template <template-name> <target-dir> [--force]

Available templates:
  rails-api-crud
  rails-modular-monolith
  rails-sidekiq-event-processing

Examples:
  script/bootstrap-template rails-api-crud /path/to/my-app
  script/bootstrap-template rails-modular-monolith ../my-app
  script/bootstrap-template rails-sidekiq-event-processing ../my-app --force

Behavior:
  - copies the selected template into the target Rails app directory
  - refuses to overwrite existing files unless --force is provided
  - auto-overwrites a small set of Rails scaffold files when they still look like fresh boilerplate
  - preserves executable bits from template scripts
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] || [ "$#" -lt 2 ]; then
  usage
  exit 0
fi

TEMPLATE_NAME="$1"
TARGET_DIR="$2"
FORCE="${3:-}"

case "$TEMPLATE_NAME" in
  rails-api-crud)
    TEMPLATE_DIR="$ROOT_DIR/template"
    ;;
  rails-modular-monolith)
    TEMPLATE_DIR="$ROOT_DIR/template-rails-modular-monolith"
    ;;
  rails-sidekiq-event-processing)
    TEMPLATE_DIR="$ROOT_DIR/template-rails-sidekiq-event-processing"
    ;;
  *)
    echo "Unknown template: $TEMPLATE_NAME"
    usage
    exit 1
    ;;
esac

if [ ! -d "$TEMPLATE_DIR" ]; then
  echo "Template directory not found: $TEMPLATE_DIR"
  exit 1
fi

mkdir -p "$TARGET_DIR"
TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"

if [ ! -d "$TARGET_DIR" ]; then
  echo "Target directory not found: $TARGET_DIR"
  exit 1
fi

if [ ! -f "$TARGET_DIR/Gemfile" ]; then
  echo "Warning: target directory does not look like a Rails app root because Gemfile was not found." >&2
fi

TEMPLATE_FILES=()
while IFS= read -r relative_path; do
  TEMPLATE_FILES+=("$relative_path")
done < <(cd "$TEMPLATE_DIR" && find . -type f | sed 's#^\./##' | sort)

is_safe_boilerplate_collision() {
  local path="$1"
  local full_path="$TARGET_DIR/$path"

  case "$path" in
    README.md)
      rg -q '^# README' "$full_path" 2>/dev/null
      ;;
    app/controllers/application_controller.rb)
      rg -q 'class ApplicationController < ActionController::(API|Base)' "$full_path" 2>/dev/null
      ;;
    app/models/application_record.rb)
      rg -q 'class ApplicationRecord < ActiveRecord::Base' "$full_path" 2>/dev/null
      ;;
    *)
      return 1
      ;;
  esac
}

collisions=()
safe_collisions=()
for relative_path in "${TEMPLATE_FILES[@]}"; do
  if [ -e "$TARGET_DIR/$relative_path" ]; then
    if is_safe_boilerplate_collision "$relative_path"; then
      safe_collisions+=("$relative_path")
    else
      collisions+=("$relative_path")
    fi
  fi
done

if [ "${#safe_collisions[@]}" -gt 0 ] && [ "$FORCE" != "--force" ]; then
  echo "Auto-overwriting Rails boilerplate files:"
  printf '  - %s\n' "${safe_collisions[@]}"
fi

if [ "${#collisions[@]}" -gt 0 ] && [ "$FORCE" != "--force" ]; then
  echo "Refusing to overwrite existing files in $TARGET_DIR"
  echo "Collisions:"
  printf '  - %s\n' "${collisions[@]}"
  echo "Re-run with --force to overwrite these files."
  exit 1
fi

echo "Installing template '$TEMPLATE_NAME' into $TARGET_DIR"

for relative_path in "${TEMPLATE_FILES[@]}"; do
  source_path="$TEMPLATE_DIR/$relative_path"
  target_path="$TARGET_DIR/$relative_path"

  mkdir -p "$(dirname "$target_path")"
  cp "$source_path" "$target_path"

  if [ -x "$source_path" ]; then
    chmod +x "$target_path"
  fi
done

echo "Template installed."
echo "Next steps:"
echo "  1. Review AGENTS.md and docs/architecture.md"
echo "  2. Adapt examples under app/ and spec/"
echo "  3. Run:"
echo "     chmod +x script/ci-fast script/ci-full script/check_harness script/check_architecture"
echo "     script/check_harness"
echo "     script/ci-fast"
