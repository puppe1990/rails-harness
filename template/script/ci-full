#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

has_gem() {
  local gem_name="$1"
  grep -q "$gem_name" Gemfile.lock 2>/dev/null || grep -q "$gem_name" Gemfile 2>/dev/null
}

echo "==> ci-fast"
script/ci-fast

echo "==> check_architecture"
script/check_architecture

if [ -d "spec" ] && has_gem "rspec-rails"; then
  echo "==> rspec full"
  if [ -f "Gemfile" ]; then
    bundle exec rspec
  else
    rspec
  fi
else
  echo "==> rspec full skipped"
fi

if [ -f ".simplecov" ] || has_gem "simplecov"; then
  echo "==> coverage hook present"
else
  echo "==> coverage hook not detected"
fi
